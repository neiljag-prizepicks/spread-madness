{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && npm install --prefix web",
  "buildCommand": "npm run build --prefix web",
  "outputDirectory": "web/dist",
  "functions": {
    "api/cron/update.mjs": {
      "maxDuration": 120,
      "memory": 1024,
      "includeFiles": "scripts/**"
    },
    "api/live/data.mjs": {
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/cron/update",
      "schedule": "*/5 * * * *"
    }
  ]
}
