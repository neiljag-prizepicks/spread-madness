# Google Sign-In (required for Google button in main.tsx)
VITE_GOOGLE_CLIENT_ID=

# Firebase (optional — enables multi-pool auth + Firestore ownership)
# From Firebase Console → Project settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Live polling (Vercel) — see web/README.md
# VITE_LIVE_POLL=1
# VITE_LIVE_POLL_MS=90000
